profile                   = assistant                            [default]
server.listen             = :7160                                [default]
server.read_timeout       = 10                                   [default]
server.write_timeout      = 20                                   [default]
server.idle_timeout       = 60                                   [default]
server.max_body_bytes     = 1048576                              [default]
store.driver              = sqlite                               [default]
store.dsn                 = ./data/stowage.db                    [default]
vindex.driver             = hnsw                                 [default]
gateway.driver            = mock                                 [default]
gateway.provider          =                                      [default]
gateway.base_url          =                                      [default]
gateway.api_key           = env.STOWAGE_GATEWAY_API_KEY (UNSET)  [default]
gateway.model             = claude-3-5-haiku-20241022            [default]
gateway.embed_model       = voyage-3-lite                        [default]
gateway.embed_dims        = 512                                  [default]
telemetry.log_level       = info                                 [default]
telemetry.log_format      = text                                 [default]
telemetry.metrics_listen  = :7161                                [default]
