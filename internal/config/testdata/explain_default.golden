profile                            = assistant                            [default]
server.listen                      = :7160                                [default]
server.mcp_listen                  =                                      [default]
server.pprof_listen                =                                      [default]
server.read_timeout                = 10                                   [default]
server.write_timeout               = 20                                   [default]
server.idle_timeout                = 60                                   [default]
server.max_body_bytes              = 1048576                              [default]
store.driver                       = sqlite                               [default]
store.dsn                          = ./data/stowage.db                    [default]
vindex.driver                      = hnsw                                 [default]
gateway.driver                     = bifrost                              [default]
gateway.provider                   = openrouter                           [default]
gateway.base_url                   =                                      [default]
gateway.api_key                    = env.STOWAGE_GATEWAY_API_KEY (UNSET)  [default]
gateway.model                      = openai/gpt-5.4-nano                  [default]
gateway.embed_model                = perplexity/pplx-embed-v1-0.6b        [default]
gateway.embed_dims                 = 1024                                 [default]
gateway.rerank_model               = cohere/rerank-4-fast                 [default]
gateway.rerank_base_url            =                                      [default]
gateway.extract_model              =                                      [default]
gateway.reconcile_model            =                                      [default]
gateway.reflect_model              =                                      [default]
gateway.embed_provider             =                                      [default]
gateway.embed_api_key              =                                      [default]
gateway.embed_base_url             =                                      [default]
gateway.rerank_provider            =                                      [default]
gateway.rerank_api_key             =                                      [default]
telemetry.log_level                = info                                 [default]
telemetry.log_format               = text                                 [default]
telemetry.metrics_listen           = :7161                                [default]
telemetry.runtime_sample_interval  = 0                                    [default]
mcp.stdio_tenant                   = default                              [default]
trace.signing_key                  =                                      [default]
retrieval.precise.lane_k           = 0                                    [default]
retrieval.precise.scoring_k        = 0                                    [default]
retrieval.precise.default_limit    = 0                                    [default]
retrieval.balanced.lane_k          = 0                                    [default]
retrieval.balanced.scoring_k       = 0                                    [default]
retrieval.balanced.default_limit   = 0                                    [default]
retrieval.broad.lane_k             = 0                                    [default]
retrieval.broad.scoring_k          = 0                                    [default]
retrieval.broad.default_limit      = 0                                    [default]
retrieval.include_superseded       = true                                 [default]
